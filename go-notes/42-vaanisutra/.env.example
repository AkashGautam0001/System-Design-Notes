# ============================================================
# VaaniSutra Environment Variables
# ============================================================
# Copy this file to .env and customize for your environment.
# All values have sensible defaults — you can run the app
# without any configuration.
# ============================================================

# Server port
PORT=8086

# Google Gemini API Key (leave empty for simulated AI mode)
GEMINI_API_KEY=

# Qdrant vector database URL (falls back to in-memory if unavailable)
QDRANT_URL=http://localhost:6333

# Qdrant collection name for storing transcript embeddings
COLLECTION_NAME=jio_transcripts

# Embedding vector dimension (must match AI model output)
EMBEDDING_DIM=256

# Number of pipeline worker goroutines
WORKER_COUNT=4

# Maximum queue size for pending transcripts
QUEUE_SIZE=100

# Timeout for batch processing operations
BATCH_TIMEOUT=5s
