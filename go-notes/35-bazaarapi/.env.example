# ============================================================
#  BazaarAPI — Environment Variables
# ============================================================
#  Copy this file to .env and adjust values for your environment.
#  WHY .env.example and not .env? Because .env may contain real
#  secrets (JWT_SECRET). We commit .env.example (with safe defaults)
#  to version control, but .env is in .gitignore.
# ============================================================

# Server
PORT=8080

# Database
DB_PATH=bazaarapi.db

# JWT Authentication
JWT_SECRET=flipkart-bigbillion-change-this-in-production
JWT_EXPIRY_HOURS=24

# HTTP Timeouts (seconds)
READ_TIMEOUT=10
WRITE_TIMEOUT=10
IDLE_TIMEOUT=120
